{
  "name": "rafka",
  "version": "0.1.0",
  "description": "Kafka-esque message queue — Node.js native addon",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "rafka-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "typecheck": "tsc --project tsconfig.json",
    "prepublishOnly": "napi build --platform --release && tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "keywords": [
    "kafka",
    "message-queue",
    "streaming",
    "native",
    "napi"
  ],
  "license": "MIT",
  "packageManager": "yarn@4.9.1"
}
